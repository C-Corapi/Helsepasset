---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Helsepasset – Trygghet hvor enn du er' } = Astro.props;
const umamiUrl = import.meta.env.PUBLIC_UMAMI_URL;
const umamiWebsiteId = import.meta.env.PUBLIC_UMAMI_WEBSITE_ID;
---

<!doctype html>
<html lang="nb">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Helsepasset</title>

    {import.meta.env.PROD && umamiUrl && umamiWebsiteId && (
      <script
        defer
        src={umamiUrl}
        data-website-id={umamiWebsiteId}
      ></script>
    )}
  </head>
  <body class="bg-white text-gray-800 antialiased">
    <!-- Navigation -->
    <header class="sticky top-0 z-50 bg-white/95 backdrop-blur supports-[backdrop-filter]:bg-white/60 border-b border-gray-100 shadow-sm">
      <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8" aria-label="Hovednavigasjon">
        <div class="flex items-center justify-between h-16">
          <a href="/" class="flex items-center space-x-2 font-bold text-xl text-primary-700 hover:text-primary-600 transition-colors" aria-label="Trygghet hvor enn du er – hjem">
            <svg class="w-9 h-9 flex-shrink-0" viewBox="0 0 56 64" fill="none" aria-hidden="true">
              <rect x="6" y="6" width="38" height="52" rx="3" stroke="currentColor" stroke-width="2.5"/>
              <path d="M36 6h8v8" stroke="currentColor" stroke-width="2.5" stroke-linejoin="round" fill="none"/>
              <line x1="36" y1="6" x2="44" y2="14" stroke="currentColor" stroke-width="1.5"/>
              <circle cx="25" cy="32" r="12" stroke="currentColor" stroke-width="2"/>
              <line x1="13" y1="32" x2="37" y2="32" stroke="currentColor" stroke-width="1.5"/>
              <ellipse cx="25" cy="32" rx="5.5" ry="12" stroke="currentColor" stroke-width="1.5" fill="none"/>
              <line x1="25" y1="24" x2="25" y2="40" stroke="#f97316" stroke-width="3" stroke-linecap="round"/>
              <line x1="17" y1="32" x2="33" y2="32" stroke="#f97316" stroke-width="3" stroke-linecap="round"/>
              <line x1="13" y1="50" x2="30" y2="50" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              <line x1="13" y1="54" x2="24" y2="54" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
            <span>Trygghet hvor enn du er</span>
          </a>

          <!-- Desktop menu -->
          <ul class="hidden md:flex items-center space-x-8" role="list">
            <li><a href="/" class="text-gray-600 hover:text-primary-600 font-medium transition-colors">Hjem</a></li>
            <li><a href="/about" class="text-gray-600 hover:text-primary-600 font-medium transition-colors">Om oss</a></li>
            <li><a href="/refer" class="text-gray-600 hover:text-primary-600 font-medium transition-colors">Anbefal</a></li>
            <li>
              <a
                href="/registrer"
                class="bg-primary-600 text-white px-4 py-2 rounded-lg font-medium hover:bg-primary-700 transition-colors"
                data-umami-event="nav-cta-click"
              >
                Opprett konto
              </a>
            </li>
          </ul>

          <!-- Mobile menu button -->
          <button
            id="mobile-menu-btn"
            type="button"
            class="md:hidden inline-flex items-center justify-center p-2 rounded-md text-gray-600 hover:text-primary-600 hover:bg-gray-100 transition-colors"
            aria-controls="mobile-menu"
            aria-expanded="false"
            aria-label="Åpne meny"
          >
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>

        <!-- Mobile menu -->
        <div id="mobile-menu" class="hidden md:hidden pb-4" role="menu">
          <ul class="flex flex-col space-y-2" role="list">
            <li><a href="/" class="block px-3 py-2 text-gray-600 hover:text-primary-600 font-medium transition-colors rounded-md hover:bg-gray-50" role="menuitem">Hjem</a></li>
            <li><a href="/about" class="block px-3 py-2 text-gray-600 hover:text-primary-600 font-medium transition-colors rounded-md hover:bg-gray-50" role="menuitem">Om oss</a></li>
            <li><a href="/refer" class="block px-3 py-2 text-gray-600 hover:text-primary-600 font-medium transition-colors rounded-md hover:bg-gray-50" role="menuitem">Anbefal</a></li>
            <li>
              <a
                href="/registrer"
                class="block px-3 py-2 bg-primary-600 text-white font-medium rounded-md hover:bg-primary-700 transition-colors text-center"
                data-umami-event="mobile-nav-cta-click"
                role="menuitem"
              >
                Opprett konto
              </a>
            </li>
          </ul>
        </div>
      </nav>
    </header>

    <!-- Page content -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-gray-900 text-gray-300 mt-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div>
            <div class="flex items-center space-x-2 font-bold text-xl text-white mb-3">
              <svg class="w-8 h-8 flex-shrink-0" viewBox="0 0 56 64" fill="none" aria-hidden="true">
                <rect x="6" y="6" width="38" height="52" rx="3" stroke="currentColor" stroke-width="2.5"/>
                <path d="M36 6h8v8" stroke="currentColor" stroke-width="2.5" stroke-linejoin="round" fill="none"/>
                <line x1="36" y1="6" x2="44" y2="14" stroke="currentColor" stroke-width="1.5"/>
                <circle cx="25" cy="32" r="12" stroke="currentColor" stroke-width="2"/>
                <line x1="13" y1="32" x2="37" y2="32" stroke="currentColor" stroke-width="1.5"/>
                <ellipse cx="25" cy="32" rx="5.5" ry="12" stroke="currentColor" stroke-width="1.5" fill="none"/>
                <line x1="25" y1="24" x2="25" y2="40" stroke="#f97316" stroke-width="3" stroke-linecap="round"/>
                <line x1="17" y1="32" x2="33" y2="32" stroke="#f97316" stroke-width="3" stroke-linecap="round"/>
                <line x1="13" y1="50" x2="30" y2="50" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                <line x1="13" y1="54" x2="24" y2="54" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              </svg>
              <span>Trygghet hvor enn du er</span>
            </div>
            <p class="text-sm text-gray-400">Trygghet hvor enn du er.</p>
          </div>

          <div>
            <h3 class="font-semibold text-white mb-3">Navigasjon</h3>
            <ul class="space-y-2 text-sm">
              <li><a href="/" class="hover:text-white transition-colors">Hjem</a></li>
              <li><a href="/about" class="hover:text-white transition-colors">Om oss</a></li>
              <li><a href="/registrer" class="hover:text-white transition-colors">Opprett konto</a></li>
              <li><a href="/refer" class="hover:text-white transition-colors">Anbefal</a></li>
            </ul>
          </div>

          <div>
            <h3 class="font-semibold text-white mb-3">Kontakt</h3>
            <address class="not-italic text-sm text-gray-400 space-y-1">
              <p>post@helsepasset.no</p>
              <p>Oslo, Norge</p>
            </address>
          </div>
        </div>

        <div class="border-t border-gray-800 mt-10 pt-6 text-sm text-gray-500 text-center">
          <p>&copy; {new Date().getFullYear()} Helsepasset. Alle rettigheter forbeholdt.</p>
        </div>
      </div>
    </footer>

    <!-- Mobile menu toggle script -->
    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      btn?.addEventListener('click', () => {
        const isOpen = menu?.classList.toggle('hidden') === false;
        btn.setAttribute('aria-expanded', String(isOpen));
        btn.setAttribute('aria-label', isOpen ? 'Lukk meny' : 'Åpne meny');
      });
    </script>
  </body>
</html>
