---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Helsepasset – Trygghet hvor enn du er' } = Astro.props;
const umamiUrl = import.meta.env.PUBLIC_UMAMI_URL;
const umamiWebsiteId = import.meta.env.PUBLIC_UMAMI_WEBSITE_ID;
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Hjem' },
  { href: '/about', label: 'Om oss' },
  { href: '/registrer', label: 'Registrer' },
];
---

<!doctype html>
<html lang="nb">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={Astro.url.href} />

    <!-- Open Graph -->
    <meta property="og:title" content={`${title} | Helsepasset`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={`${title} | Helsepasset`} />
    <meta name="twitter:description" content={description} />

    <title>{title} | Helsepasset</title>

    <!-- Fonts: Inter + Fraunces -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    {import.meta.env.PROD && umamiUrl && umamiWebsiteId && (
      <script
        defer
        src={umamiUrl}
        data-website-id={umamiWebsiteId}
      ></script>
    )}
  </head>
  <body>
    <!-- Skip to content -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:px-4 focus:py-2 focus:bg-primary focus:text-primary-foreground focus:rounded-full focus:text-sm focus:font-medium"
    >
      Hopp til innhold
    </a>

    <!-- Navigation -->
    <header
      id="site-header"
      class="sticky top-0 z-50 bg-background/70 backdrop-blur-md border-b border-transparent transition-colors duration-300"
    >
      <nav class="max-w-[1200px] mx-auto px-6" aria-label="Hovedmeny">
        <div class="flex items-center justify-between h-16">
          <!-- Logo -->
          <a href="/" class="flex items-center gap-2 font-serif text-xl font-semibold text-foreground hover:opacity-80 transition-opacity" aria-label="Helsepasset – hjem">
            <svg class="w-8 h-8 flex-shrink-0" viewBox="0 0 56 64" fill="none" aria-hidden="true">
              <rect x="6" y="6" width="38" height="52" rx="3" stroke="currentColor" stroke-width="2.5"/>
              <path d="M36 6h8v8" stroke="currentColor" stroke-width="2.5" stroke-linejoin="round" fill="none"/>
              <line x1="36" y1="6" x2="44" y2="14" stroke="currentColor" stroke-width="1.5"/>
              <circle cx="25" cy="32" r="12" stroke="currentColor" stroke-width="2"/>
              <line x1="13" y1="32" x2="37" y2="32" stroke="currentColor" stroke-width="1.5"/>
              <ellipse cx="25" cy="32" rx="5.5" ry="12" stroke="currentColor" stroke-width="1.5" fill="none"/>
              <line x1="25" y1="24" x2="25" y2="40" stroke="hsl(var(--accent))" stroke-width="3" stroke-linecap="round"/>
              <line x1="17" y1="32" x2="33" y2="32" stroke="hsl(var(--accent))" stroke-width="3" stroke-linecap="round"/>
              <line x1="13" y1="50" x2="30" y2="50" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              <line x1="13" y1="54" x2="24" y2="54" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
            <span>Helsepasset</span>
          </a>

          <!-- Desktop menu -->
          <ul class="hidden md:flex items-center gap-8" role="list">
            {navLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class:list={[
                    'text-sm font-medium transition-colors duration-200 relative',
                    currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                      ? 'text-foreground after:absolute after:bottom-[-4px] after:left-0 after:w-full after:h-0.5 after:bg-accent after:rounded-full'
                      : 'text-muted-foreground hover:text-foreground',
                  ]}
                >
                  {link.label}
                </a>
              </li>
            ))}
            <li>
              <a
                href="/registrer"
                class="bg-primary text-primary-foreground text-sm font-medium px-6 py-2.5 rounded-full hover:bg-primary/90 hover:shadow-soft-lg transition-all duration-200"
                data-umami-event="nav-cta-click"
              >
                Opprett konto
              </a>
            </li>
          </ul>

          <!-- Mobile menu button -->
          <button
            id="mobile-menu-btn"
            type="button"
            class="md:hidden inline-flex items-center justify-center p-2 rounded-lg text-foreground hover:bg-secondary transition-colors"
            aria-controls="mobile-menu-panel"
            aria-expanded="false"
            aria-label="Åpne meny"
          >
            <svg id="menu-icon-open" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
            <svg id="menu-icon-close" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
      </nav>

      <!-- Mobile menu panel (slide-over) -->
      <div
        id="mobile-menu-overlay"
        class="fixed inset-0 bg-foreground/30 backdrop-blur-sm z-40 hidden md:hidden transition-opacity"
        aria-hidden="true"
      ></div>
      <div
        id="mobile-menu-panel"
        class="fixed top-0 right-0 h-full w-72 bg-card z-50 shadow-soft-lg transform translate-x-full transition-transform duration-300 md:hidden"
        role="dialog"
        aria-modal="true"
        aria-label="Mobilmeny"
      >
        <div class="flex items-center justify-between px-6 h-16 border-b border-border">
          <span class="font-serif font-semibold text-foreground">Meny</span>
          <button
            id="mobile-menu-close"
            type="button"
            class="p-2 rounded-lg text-foreground hover:bg-secondary transition-colors"
            aria-label="Lukk meny"
          >
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
        <ul class="px-6 py-6 space-y-2" role="list">
          {navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class:list={[
                  'block px-4 py-3 rounded-xl text-sm font-medium transition-colors',
                  currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                    ? 'bg-secondary text-foreground'
                    : 'text-muted-foreground hover:bg-secondary hover:text-foreground',
                ]}
              >
                {link.label}
              </a>
            </li>
          ))}
          <li class="pt-4">
            <a
              href="/registrer"
              class="block w-full text-center bg-primary text-primary-foreground text-sm font-medium px-6 py-3 rounded-full hover:bg-primary/90 transition-colors"
              data-umami-event="mobile-nav-cta-click"
            >
              Opprett konto
            </a>
          </li>
        </ul>
      </div>
    </header>

    <!-- Page content -->
    <main id="main-content">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-foreground text-primary-foreground/70 mt-0">
      <div class="max-w-[1200px] mx-auto px-6 py-16">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10">
          <!-- Brand -->
          <div>
            <div class="flex items-center gap-2 font-serif text-lg font-semibold text-primary-foreground mb-3">
              <svg class="w-7 h-7 flex-shrink-0" viewBox="0 0 56 64" fill="none" aria-hidden="true">
                <rect x="6" y="6" width="38" height="52" rx="3" stroke="currentColor" stroke-width="2.5"/>
                <path d="M36 6h8v8" stroke="currentColor" stroke-width="2.5" stroke-linejoin="round" fill="none"/>
                <line x1="36" y1="6" x2="44" y2="14" stroke="currentColor" stroke-width="1.5"/>
                <circle cx="25" cy="32" r="12" stroke="currentColor" stroke-width="2"/>
                <line x1="13" y1="32" x2="37" y2="32" stroke="currentColor" stroke-width="1.5"/>
                <ellipse cx="25" cy="32" rx="5.5" ry="12" stroke="currentColor" stroke-width="1.5" fill="none"/>
                <line x1="25" y1="24" x2="25" y2="40" stroke="hsl(var(--accent))" stroke-width="3" stroke-linecap="round"/>
                <line x1="17" y1="32" x2="33" y2="32" stroke="hsl(var(--accent))" stroke-width="3" stroke-linecap="round"/>
                <line x1="13" y1="50" x2="30" y2="50" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                <line x1="13" y1="54" x2="24" y2="54" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              </svg>
              <span>Helsepasset</span>
            </div>
            <p class="text-sm">Ditt helsepass, alltid med deg.</p>
          </div>

          <!-- Produkt -->
          <div>
            <h3 class="font-semibold text-primary-foreground mb-4 text-sm uppercase tracking-wider">Produkt</h3>
            <ul class="space-y-2 text-sm">
              <li><a href="/" class="hover:text-primary-foreground transition-colors">Hjem</a></li>
              <li><a href="/about" class="hover:text-primary-foreground transition-colors">Om oss</a></li>
              <li><a href="/registrer" class="hover:text-primary-foreground transition-colors">Registrer</a></li>
              <li><a href="/refer" class="hover:text-primary-foreground transition-colors">Anbefal</a></li>
            </ul>
          </div>

          <!-- Selskap -->
          <div>
            <h3 class="font-semibold text-primary-foreground mb-4 text-sm uppercase tracking-wider">Selskap</h3>
            <ul class="space-y-2 text-sm">
              <li><a href="/about" class="hover:text-primary-foreground transition-colors">Personvern</a></li>
              <li><a href="/about" class="hover:text-primary-foreground transition-colors">Vilkår</a></li>
              <li><a href="mailto:post@helsepasset.no" class="hover:text-primary-foreground transition-colors">Kontakt</a></li>
            </ul>
          </div>

          <!-- Newsletter -->
          <div>
            <h3 class="font-semibold text-primary-foreground mb-4 text-sm uppercase tracking-wider">Hold deg oppdatert</h3>
            <form class="flex gap-2" aria-label="Nyhetsbrev">
              <label for="newsletter-email" class="sr-only">E-postadresse</label>
              <input
                type="email"
                id="newsletter-email"
                placeholder="Din e-post"
                class="flex-1 min-w-0 px-4 py-2 rounded-full bg-primary-foreground/10 border border-primary-foreground/20 text-primary-foreground text-sm placeholder:text-primary-foreground/40 focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-0"
                aria-required="true"
              />
              <button
                type="submit"
                class="px-4 py-2 bg-accent text-accent-foreground text-sm font-medium rounded-full hover:brightness-105 transition-all shadow-soft whitespace-nowrap"
              >
                Meld meg på
              </button>
            </form>
          </div>
        </div>

        <div class="border-t border-primary-foreground/10 mt-12 pt-6 text-sm text-primary-foreground/40 text-center">
          <p>&copy; Helsepasset {new Date().getFullYear()} · Laget i Norge</p>
        </div>
      </div>
    </footer>

    <!-- Header scroll effect + Mobile menu script -->
    <script>
      // Header border on scroll
      const header = document.getElementById('site-header');
      function updateHeader() {
        if (!header) return;
        if (window.scrollY > 10) {
          header.classList.add('border-border');
          header.classList.remove('border-transparent');
        } else {
          header.classList.remove('border-border');
          header.classList.add('border-transparent');
        }
      }
      window.addEventListener('scroll', updateHeader, { passive: true });
      updateHeader();

      // Mobile menu
      const mobileBtn = document.getElementById('mobile-menu-btn');
      const mobileCloseBtn = document.getElementById('mobile-menu-close');
      const mobileOverlay = document.getElementById('mobile-menu-overlay');
      const mobilePanel = document.getElementById('mobile-menu-panel');
      const openIcon = document.getElementById('menu-icon-open');
      const closeIcon = document.getElementById('menu-icon-close');

      function openMobileMenu() {
        mobileOverlay?.classList.remove('hidden');
        mobilePanel?.classList.remove('translate-x-full');
        mobilePanel?.classList.add('translate-x-0');
        openIcon?.classList.add('hidden');
        closeIcon?.classList.remove('hidden');
        mobileBtn?.setAttribute('aria-expanded', 'true');
        document.body.style.overflow = 'hidden';
        // Trap focus
        const firstFocusable = mobilePanel?.querySelector('a, button') as HTMLElement | null;
        firstFocusable?.focus();
      }

      function closeMobileMenu() {
        mobileOverlay?.classList.add('hidden');
        mobilePanel?.classList.add('translate-x-full');
        mobilePanel?.classList.remove('translate-x-0');
        openIcon?.classList.remove('hidden');
        closeIcon?.classList.add('hidden');
        mobileBtn?.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
        mobileBtn?.focus();
      }

      mobileBtn?.addEventListener('click', openMobileMenu);
      mobileCloseBtn?.addEventListener('click', closeMobileMenu);
      mobileOverlay?.addEventListener('click', closeMobileMenu);

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && mobileBtn?.getAttribute('aria-expanded') === 'true') {
          closeMobileMenu();
        }
      });
    </script>

    <!-- Scroll reveal observer -->
    <script>
      function initReveal() {
        const revealEls = document.querySelectorAll('[data-reveal]');
        if (!revealEls.length) return;

        const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (prefersReduced) {
          revealEls.forEach(el => {
            (el as HTMLElement).style.opacity = '1';
            (el as HTMLElement).style.transform = 'none';
          });
          return;
        }

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                (entry.target as HTMLElement).classList.add('animate-fade-up');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.15 }
        );

        revealEls.forEach((el) => {
          (el as HTMLElement).style.opacity = '0';
          observer.observe(el);
        });
      }

      initReveal();
    </script>
  </body>
</html>
