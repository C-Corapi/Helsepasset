---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Opprett konto" description="Opprett din konto hos Helsepasset – få tilgang til personlig helseinformasjon.">
  <!-- Page header -->
  <section class="bg-gradient-to-br from-primary-700 to-primary-500 text-white py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl sm:text-5xl font-extrabold mb-4">Opprett konto</h1>
      <p class="text-primary-100 text-lg max-w-xl mx-auto">
        Registrer deg for å motta oppdateringer og få tilgang til ditt personlige helsepass.
      </p>
    </div>
  </section>

  <!-- Registration form -->
  <section class="py-20" aria-labelledby="register-form-heading">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 id="register-form-heading" class="text-2xl font-bold text-gray-900 mb-6">Fyll ut dine opplysninger</h2>

      <!-- Success message (hidden by default) -->
      <div
        id="register-success"
        class="hidden mb-6 p-4 bg-green-50 border border-green-200 text-green-800 rounded-lg"
        role="alert"
      >
        <p class="font-semibold">Konto opprettet!</p>
        <p class="text-sm mt-1">Takk for registreringen. Vi tar kontakt med mer informasjon snart.</p>
        <a href="/refer" class="inline-block mt-3 text-sm font-medium text-primary-600 hover:text-primary-700 underline">
          Anbefal Helsepasset til noen du kjenner →
        </a>
      </div>

      <!-- Error message (hidden by default) -->
      <div
        id="register-error"
        class="hidden mb-6 p-4 bg-red-50 border border-red-200 text-red-800 rounded-lg"
        role="alert"
      >
        <p class="font-semibold">Noe gikk galt</p>
        <p id="register-error-msg" class="text-sm mt-1"></p>
      </div>

      <form
        id="register-form"
        class="space-y-5"
        novalidate
        aria-label="Registreringsskjema"
      >
        <!-- Fornavn / Etternavn -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <div>
            <label for="fornavn" class="block text-sm font-medium text-gray-700 mb-1.5">
              Fornavn <span class="text-red-500" aria-label="obligatorisk">*</span>
            </label>
            <input
              type="text"
              id="fornavn"
              name="fornavn"
              required
              autocomplete="given-name"
              class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors outline-none"
              placeholder="Ola"
              aria-required="true"
            />
          </div>

          <div>
            <label for="etternavn" class="block text-sm font-medium text-gray-700 mb-1.5">
              Etternavn <span class="text-red-500" aria-label="obligatorisk">*</span>
            </label>
            <input
              type="text"
              id="etternavn"
              name="etternavn"
              required
              autocomplete="family-name"
              class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors outline-none"
              placeholder="Nordmann"
              aria-required="true"
            />
          </div>
        </div>

        <!-- E-post -->
        <div>
          <label for="epost" class="block text-sm font-medium text-gray-700 mb-1.5">
            E-post <span class="text-red-500" aria-label="obligatorisk">*</span>
          </label>
          <input
            type="email"
            id="epost"
            name="epost"
            required
            autocomplete="email"
            class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors outline-none"
            placeholder="ola@eksempel.no"
            aria-required="true"
          />
        </div>

        <!-- Telefon -->
        <div>
          <label for="telefon" class="block text-sm font-medium text-gray-700 mb-1.5">
            Telefonnummer <span class="text-red-500" aria-label="obligatorisk">*</span>
          </label>
          <input
            type="tel"
            id="telefon"
            name="telefon"
            required
            autocomplete="tel"
            class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors outline-none"
            placeholder="+47 000 00 000"
            aria-required="true"
          />
        </div>

        <!-- Fødselsdato -->
        <div>
          <label for="fodselsdato" class="block text-sm font-medium text-gray-700 mb-1.5">
            Fødselsdato <span class="text-red-500" aria-label="obligatorisk">*</span>
          </label>
          <input
            type="date"
            id="fodselsdato"
            name="fodselsdato"
            required
            autocomplete="bday"
            class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors outline-none"
            aria-required="true"
          />
        </div>

        <!-- Kjønn -->
        <div>
          <label for="kjonn" class="block text-sm font-medium text-gray-700 mb-1.5">
            Kjønn <span class="text-red-500" aria-label="obligatorisk">*</span>
          </label>
          <select
            id="kjonn"
            name="kjonn"
            required
            class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors outline-none bg-white"
            aria-required="true"
          >
            <option value="" disabled selected>Velg kjønn</option>
            <option value="mann">Mann</option>
            <option value="kvinne">Kvinne</option>
            <option value="annet">Annet</option>
            <option value="ikke_oppgitt">Ønsker ikke å oppgi</option>
          </select>
        </div>

        <!-- Adresse -->
        <div>
          <label for="adresse" class="block text-sm font-medium text-gray-700 mb-1.5">
            Adresse <span class="text-red-500" aria-label="obligatorisk">*</span>
          </label>
          <input
            type="text"
            id="adresse"
            name="adresse"
            required
            autocomplete="street-address"
            class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors outline-none"
            placeholder="Gateadresse 1"
            aria-required="true"
          />
        </div>

        <!-- Postnummer / Sted -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <div>
            <label for="postnummer" class="block text-sm font-medium text-gray-700 mb-1.5">
              Postnummer <span class="text-red-500" aria-label="obligatorisk">*</span>
            </label>
            <input
              type="text"
              id="postnummer"
              name="postnummer"
              required
              autocomplete="postal-code"
              inputmode="numeric"
              pattern="[0-9]{4}"
              maxlength="4"
              class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors outline-none"
              placeholder="0001"
              aria-required="true"
            />
          </div>

          <div>
            <label for="sted" class="block text-sm font-medium text-gray-700 mb-1.5">
              Sted <span class="text-red-500" aria-label="obligatorisk">*</span>
            </label>
            <input
              type="text"
              id="sted"
              name="sted"
              required
              autocomplete="address-level2"
              class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors outline-none"
              placeholder="Oslo"
              aria-required="true"
            />
          </div>
        </div>

        <!-- Samtykke -->
        <div class="flex items-start gap-3">
          <input
            type="checkbox"
            id="samtykke"
            name="samtykke"
            required
            class="mt-1 h-4 w-4 text-primary-600 border-gray-300 rounded focus:ring-primary-500"
            aria-required="true"
          />
          <label for="samtykke" class="text-sm text-gray-600">
            Jeg samtykker til at Helsepasset lagrer mine opplysninger i henhold til
            <span class="text-primary-600 font-medium">personvernvilkårene</span>.
            <span class="text-red-500" aria-label="obligatorisk">*</span>
          </label>
        </div>

        <!-- Submit -->
        <button
          type="submit"
          class="w-full bg-primary-600 text-white font-semibold py-3 px-6 rounded-lg hover:bg-primary-700 active:bg-primary-800 transition-colors text-lg focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2"
          data-umami-event="register-form-submit"
        >
          Opprett konto
        </button>

        <p class="text-center text-sm text-gray-500 mt-4">
          Kjenner du noen som også bør registrere seg?
          <a href="/refer" class="text-primary-600 hover:text-primary-700 font-medium underline">
            Anbefal Helsepasset →
          </a>
        </p>
      </form>
    </div>
  </section>
</Layout>

<script>
  import { createAccount } from '../utils/supabase';
  import type { AccountRecord } from '../utils/supabase';

  const form = document.getElementById('register-form') as HTMLFormElement | null;
  const successEl = document.getElementById('register-success');
  const errorEl = document.getElementById('register-error');
  const errorMsg = document.getElementById('register-error-msg');

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();

    // Reset alerts
    successEl?.classList.add('hidden');
    errorEl?.classList.add('hidden');

    // Gather values
    const get = (id: string) =>
      (document.getElementById(id) as HTMLInputElement | HTMLSelectElement | null)?.value.trim() ?? '';
    const samtykke = (document.getElementById('samtykke') as HTMLInputElement | null)?.checked ?? false;

    // Basic client-side validation
    const required = ['fornavn', 'etternavn', 'epost', 'telefon', 'fodselsdato', 'kjonn', 'adresse', 'postnummer', 'sted'];
    for (const id of required) {
      if (!get(id)) {
        showError('Vennligst fyll ut alle obligatoriske felt.');
        return;
      }
    }

    if (!samtykke) {
      showError('Du må samtykke til personvernvilkårene for å opprette en konto.');
      return;
    }

    // Email validation
    const epost = get('epost');
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(epost)) {
      showError('Vennligst oppgi en gyldig e-postadresse.');
      return;
    }

    // Postal code validation (4 digits for Norway)
    const postnummer = get('postnummer');
    if (!/^[0-9]{4}$/.test(postnummer)) {
      showError('Postnummer må bestå av 4 siffer.');
      return;
    }

    const data: AccountRecord = {
      fornavn: get('fornavn'),
      etternavn: get('etternavn'),
      epost,
      telefon: get('telefon'),
      fodselsdato: get('fodselsdato'),
      kjonn: get('kjonn'),
      adresse: get('adresse'),
      postnummer,
      sted: get('sted'),
      samtykke,
    };

    // Track with Umami
    if (typeof window !== 'undefined' && 'umami' in window) {
      // @ts-expect-error - umami is injected via script tag
      window.umami.track('register-form-submitted');
    }

    const result = await createAccount(data);

    if (result.success) {
      successEl?.classList.remove('hidden');
      form.reset();
      form.classList.add('hidden');
      successEl?.scrollIntoView({ behavior: 'smooth', block: 'center' });
    } else {
      showError(result.error ?? 'En ukjent feil oppstod. Prøv igjen senere.');
    }
  });

  function showError(message: string) {
    if (errorEl && errorMsg) {
      errorMsg.textContent = message;
      errorEl.classList.remove('hidden');
      errorEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
  }
</script>
