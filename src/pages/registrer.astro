---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Opprett konto" description="Opprett din konto hos Helsepasset – få tilgang til personlig helseinformasjon.">
  <!-- Page header -->
  <section class="bg-gradient-to-br from-primary-700 to-primary-500 text-white py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl sm:text-5xl font-extrabold mb-4">[Registration page headline – e.g. "Create your account"]</h1>
      <p class="text-primary-100 text-lg max-w-xl mx-auto">
        [1–2 sentences explaining what registering gives access to – what does the user unlock by signing up?]
      </p>
    </div>
  </section>

  <!-- Registration form -->
  <section class="py-20" aria-labelledby="register-form-heading">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 id="register-form-heading" class="text-2xl font-bold text-gray-900 mb-6">[Registration form heading – e.g. "Fill in your details"]</h2>

      <!-- Success message (hidden by default) -->
      <div
        id="register-success"
        class="hidden mb-6 p-4 bg-green-50 border border-green-200 text-green-800 rounded-lg"
        role="alert"
      >
        <p class="font-semibold">Konto opprettet!</p>
        <p class="text-sm mt-1">Takk for registreringen. Sjekk e-posten din for å bekrefte kontoen.</p>
        <a href="/refer" class="inline-block mt-3 text-sm font-medium text-primary-600 hover:text-primary-700 underline">
          Anbefal Helsepasset til noen du kjenner →
        </a>
      </div>

      <!-- Error message (hidden by default) -->
      <div
        id="register-error"
        class="hidden mb-6 p-4 bg-red-50 border border-red-200 text-red-800 rounded-lg"
        role="alert"
      >
        <p class="font-semibold">Noe gikk galt</p>
        <p id="register-error-msg" class="text-sm mt-1"></p>
      </div>

      <form
        id="register-form"
        class="space-y-5"
        novalidate
        aria-label="Registreringsskjema"
      >
        <!-- Fornavn / Etternavn -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <div>
            <label for="fornavn" class="block text-sm font-medium text-gray-700 mb-1.5">
              Fornavn <span class="text-red-500" aria-label="obligatorisk">*</span>
            </label>
            <input
              type="text"
              id="fornavn"
              name="fornavn"
              required
              autocomplete="given-name"
              class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors outline-none"
              placeholder="Ola"
              aria-required="true"
            />
          </div>

          <div>
            <label for="etternavn" class="block text-sm font-medium text-gray-700 mb-1.5">
              Etternavn <span class="text-red-500" aria-label="obligatorisk">*</span>
            </label>
            <input
              type="text"
              id="etternavn"
              name="etternavn"
              required
              autocomplete="family-name"
              class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors outline-none"
              placeholder="Nordmann"
              aria-required="true"
            />
          </div>
        </div>

        <!-- E-post -->
        <div>
          <label for="epost" class="block text-sm font-medium text-gray-700 mb-1.5">
            E-post <span class="text-red-500" aria-label="obligatorisk">*</span>
          </label>
          <input
            type="email"
            id="epost"
            name="epost"
            required
            autocomplete="email"
            class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors outline-none"
            placeholder="ola@eksempel.no"
            aria-required="true"
          />
        </div>

        <!-- Passord -->
        <div>
          <label for="passord" class="block text-sm font-medium text-gray-700 mb-1.5">
            Passord <span class="text-red-500" aria-label="obligatorisk">*</span>
          </label>
          <input
            type="password"
            id="passord"
            name="passord"
            required
            minlength="8"
            autocomplete="new-password"
            class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors outline-none"
            placeholder="Minst 8 tegn"
            aria-required="true"
          />
        </div>

        <!-- Bekreft passord -->
        <div>
          <label for="passord-bekreft" class="block text-sm font-medium text-gray-700 mb-1.5">
            Gjenta passord <span class="text-red-500" aria-label="obligatorisk">*</span>
          </label>
          <input
            type="password"
            id="passord-bekreft"
            name="passord-bekreft"
            required
            minlength="8"
            autocomplete="new-password"
            class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors outline-none"
            placeholder="Gjenta passordet ditt"
            aria-required="true"
          />
        </div>

        <!-- Samtykke til vilkår -->
        <div class="flex items-start gap-3">
          <input
            type="checkbox"
            id="samtykke-vilkar"
            name="samtykke-vilkar"
            required
            class="mt-1 h-4 w-4 text-primary-600 border-gray-300 rounded focus:ring-primary-500"
            aria-required="true"
          />
          <label for="samtykke-vilkar" class="text-sm text-gray-600">
            Jeg godtar <a href="/about" class="text-primary-600 font-medium underline hover:text-primary-700">vilkår og betingelser</a>.
            <span class="text-red-500" aria-label="obligatorisk">*</span>
          </label>
        </div>

        <!-- Samtykke til nyhetsbrev -->
        <div class="flex items-start gap-3">
          <input
            type="checkbox"
            id="samtykke-nyhetsbrev"
            name="samtykke-nyhetsbrev"
            required
            class="mt-1 h-4 w-4 text-primary-600 border-gray-300 rounded focus:ring-primary-500"
            aria-required="true"
          />
          <label for="samtykke-nyhetsbrev" class="text-sm text-gray-600">
            Jeg samtykker til å motta nyhetsbrev.
            <span class="text-red-500" aria-label="obligatorisk">*</span>
          </label>
        </div>

        <!-- Submit -->
        <button
          type="submit"
          class="w-full bg-primary-600 text-white font-semibold py-3 px-6 rounded-lg hover:bg-primary-700 active:bg-primary-800 transition-colors text-lg focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2"
          data-umami-event="register-form-submit"
        >
          Opprett konto
        </button>

        <p class="text-center text-sm text-gray-500 mt-4">
          Kjenner du noen som også bør registrere seg?
          <a href="/refer" class="text-primary-600 hover:text-primary-700 font-medium underline">
            Anbefal Helsepasset →
          </a>
        </p>
      </form>
    </div>
  </section>
</Layout>

<script>
  import { createAccount } from '../utils/supabase';
  import type { AccountRecord } from '../utils/supabase';
  import { isValidEmail } from '../utils/validation';

  const form = document.getElementById('register-form') as HTMLFormElement | null;
  const successEl = document.getElementById('register-success');
  const errorEl = document.getElementById('register-error');
  const errorMsg = document.getElementById('register-error-msg');

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();

    // Reset alerts
    successEl?.classList.add('hidden');
    errorEl?.classList.add('hidden');

    // Gather values
    const get = (id: string) =>
      (document.getElementById(id) as HTMLInputElement | HTMLSelectElement | null)?.value.trim() ?? '';
    const samtykkeVilkar = (document.getElementById('samtykke-vilkar') as HTMLInputElement | null)?.checked ?? false;
    const samtykkeNyhetsbrev = (document.getElementById('samtykke-nyhetsbrev') as HTMLInputElement | null)?.checked ?? false;

    // Basic client-side validation
    const required = ['fornavn', 'etternavn', 'epost', 'passord', 'passord-bekreft'];
    for (const id of required) {
      if (!get(id)) {
        showError('Vennligst fyll ut alle obligatoriske felt.');
        return;
      }
    }

    if (!samtykkeVilkar) {
      showError('Du må godta vilkår og betingelser for å opprette en konto.');
      return;
    }

    if (!samtykkeNyhetsbrev) {
      showError('Du må samtykke til å motta nyhetsbrev for å opprette en konto.');
      return;
    }

    // Email validation
    const epost = get('epost');
    if (!isValidEmail(epost)) {
      showError('Vennligst oppgi en gyldig e-postadresse.');
      return;
    }

    const passord = get('passord');
    const passordBekreft = get('passord-bekreft');
    if (passord.length < 8) {
      showError('Passordet må være minst 8 tegn.');
      return;
    }

    if (passord !== passordBekreft) {
      showError('Passordene er ikke like.');
      return;
    }

    const data: AccountRecord = {
      fornavn: get('fornavn'),
      etternavn: get('etternavn'),
      epost,
      samtykke_vilkar: samtykkeVilkar,
      nyhetsbrev: samtykkeNyhetsbrev,
    };

    // Track with Umami
    if (typeof window !== 'undefined' && 'umami' in window) {
      // @ts-expect-error - umami is injected via script tag
      window.umami.track('register-form-submitted');
    }

    const result = await createAccount(data, passord);

    if (result.success) {
      successEl?.classList.remove('hidden');
      form.reset();
      form.classList.add('hidden');
      successEl?.scrollIntoView({ behavior: 'smooth', block: 'center' });
    } else {
      showError(result.error ?? 'En ukjent feil oppstod. Prøv igjen senere.');
    }
  });

  function showError(message: string) {
    if (errorEl && errorMsg) {
      errorMsg.textContent = message;
      errorEl.classList.remove('hidden');
      errorEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
  }
</script>
