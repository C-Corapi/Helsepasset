---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Opprett konto — Helsepasset" description="Opprett din konto hos Helsepasset – få tilgang til personlig helseinformasjon.">

  <section class="min-h-screen py-24 md:py-0">
    <div class="max-w-[1200px] mx-auto px-6 grid md:grid-cols-2 gap-0 md:min-h-[calc(100vh-4rem)]">

      <!-- Left: form column -->
      <div class="flex flex-col justify-center py-12 md:py-20 md:pr-12" data-hp-reveal>
        <h1 class="font-serif font-bold text-ink text-3xl mb-3">Opprett konto</h1>
        <p class="text-muted-ink mb-8" style="font-size: 1.0625rem; line-height: 1.7;">
          Registrer deg for å motta oppdateringer og få tilgang til ditt personlige helsepass.
        </p>

        <!-- Success message (hidden by default) -->
        <div
          id="register-success"
          class="hidden mb-6 p-5 bg-sage/10 border border-sage/30 text-ink rounded-2xl"
          role="alert"
        >
          <p class="font-semibold mb-1">Konto opprettet!</p>
          <p class="text-sm text-muted-ink">Takk for registreringen. Sjekk e-posten din for å bekrefte kontoen.</p>
          <a href="/refer" class="inline-block mt-3 text-sm font-medium text-forest underline hover:text-forest/80">
            Anbefal Helsepasset til noen du kjenner →
          </a>
        </div>

        <!-- Error message (hidden by default) -->
        <div
          id="register-error"
          class="hidden mb-6 p-5 bg-danger/5 border border-danger/20 text-ink rounded-2xl"
          role="alert"
        >
          <p class="font-semibold">Noe gikk galt</p>
          <p id="register-error-msg" class="text-sm text-muted-ink mt-1"></p>
        </div>

        <!-- Form card -->
        <div class="rounded-3xl border border-edge bg-card p-8">
          <h2 class="font-serif text-lg font-semibold text-ink mb-6">Fyll ut dine opplysninger</h2>
          <form
            id="register-form"
            class="space-y-5"
            novalidate
            aria-label="Registreringsskjema"
          >
            <!-- Fornavn / Etternavn -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label for="fornavn" class="block text-sm font-medium text-ink mb-1.5">
                  Fornavn <span class="text-danger" aria-label="obligatorisk">*</span>
                </label>
                <input
                  type="text"
                  id="fornavn"
                  name="fornavn"
                  required
                  autocomplete="given-name"
                  class="w-full px-4 py-2.5 border border-edge rounded-xl bg-sand focus:ring-2 focus:ring-focus focus:border-focus transition-colors outline-none text-ink"
                  placeholder="Ola"
                  aria-required="true"
                />
              </div>
              <div>
                <label for="etternavn" class="block text-sm font-medium text-ink mb-1.5">
                  Etternavn <span class="text-danger" aria-label="obligatorisk">*</span>
                </label>
                <input
                  type="text"
                  id="etternavn"
                  name="etternavn"
                  required
                  autocomplete="family-name"
                  class="w-full px-4 py-2.5 border border-edge rounded-xl bg-sand focus:ring-2 focus:ring-focus focus:border-focus transition-colors outline-none text-ink"
                  placeholder="Nordmann"
                  aria-required="true"
                />
              </div>
            </div>

            <!-- E-post -->
            <div>
              <label for="epost" class="block text-sm font-medium text-ink mb-1.5">
                E-post <span class="text-danger" aria-label="obligatorisk">*</span>
              </label>
              <input
                type="email"
                id="epost"
                name="epost"
                required
                autocomplete="email"
                class="w-full px-4 py-2.5 border border-edge rounded-xl bg-sand focus:ring-2 focus:ring-focus focus:border-focus transition-colors outline-none text-ink"
                placeholder="ola@eksempel.no"
                aria-required="true"
              />
            </div>

            <!-- Passord -->
            <div>
              <label for="passord" class="block text-sm font-medium text-ink mb-1.5">
                Passord <span class="text-danger" aria-label="obligatorisk">*</span>
              </label>
              <input
                type="password"
                id="passord"
                name="passord"
                required
                minlength="8"
                autocomplete="new-password"
                class="w-full px-4 py-2.5 border border-edge rounded-xl bg-sand focus:ring-2 focus:ring-focus focus:border-focus transition-colors outline-none text-ink"
                placeholder="Minst 8 tegn"
                aria-required="true"
              />
            </div>

            <!-- Gjenta passord -->
            <div>
              <label for="passord-bekreft" class="block text-sm font-medium text-ink mb-1.5">
                Gjenta passord <span class="text-danger" aria-label="obligatorisk">*</span>
              </label>
              <input
                type="password"
                id="passord-bekreft"
                name="passord-bekreft"
                required
                minlength="8"
                autocomplete="new-password"
                class="w-full px-4 py-2.5 border border-edge rounded-xl bg-sand focus:ring-2 focus:ring-focus focus:border-focus transition-colors outline-none text-ink"
                placeholder="Gjenta passordet ditt"
                aria-required="true"
              />
            </div>

            <!-- Checkboxes -->
            <div class="flex items-start gap-3">
              <input
                type="checkbox"
                id="samtykke-vilkar"
                name="samtykke-vilkar"
                required
                class="mt-1 h-4 w-4 text-forest border-edge rounded focus:ring-focus"
                aria-required="true"
              />
              <label for="samtykke-vilkar" class="text-sm text-muted-ink">
                Jeg godtar <a href="/about" class="text-forest font-medium underline hover:text-forest/80">vilkår og betingelser</a>.
                <span class="text-danger" aria-label="obligatorisk">*</span>
              </label>
            </div>

            <div class="flex items-start gap-3">
              <input
                type="checkbox"
                id="samtykke-nyhetsbrev"
                name="samtykke-nyhetsbrev"
                required
                class="mt-1 h-4 w-4 text-forest border-edge rounded focus:ring-focus"
                aria-required="true"
              />
              <label for="samtykke-nyhetsbrev" class="text-sm text-muted-ink">
                Jeg samtykker til å motta nyhetsbrev.
                <span class="text-danger" aria-label="obligatorisk">*</span>
              </label>
            </div>

            <!-- Submit -->
            <button
              type="submit"
              class="w-full bg-forest text-forest-contrast font-semibold py-3 px-6 rounded-full hover:bg-forest/90 active:bg-forest/80 transition-colors text-sm focus:outline-none focus:ring-2 focus:ring-focus focus:ring-offset-2"
              data-umami-event="register-form-submit"
            >
              Opprett konto
            </button>

            <p class="text-center text-sm text-muted-ink mt-4">
              Kjenner du noen som også bør registrere seg?
              <a href="/refer" class="text-forest hover:text-forest/80 font-medium underline">
                Anbefal Helsepasset →
              </a>
            </p>
          </form>
        </div>
      </div>

      <!-- Right: reassurance panel -->
      <div class="hidden md:flex flex-col justify-center bg-mint rounded-3xl my-8 p-10 lg:p-14" data-hp-reveal style="animation-delay: 100ms">
        <!-- Mini phone mockup -->
        <div class="mx-auto mb-10 rounded-[2rem] border-4 border-ink/20 bg-card w-48 shadow-hp overflow-hidden" style="aspect-ratio: 9/16;" aria-hidden="true">
          <div class="flex flex-col items-center justify-center h-full p-4">
            <div class="w-full rounded-xl bg-gradient-to-br from-sage/30 to-mint p-3 text-center">
              <p class="text-[9px] uppercase tracking-widest text-muted-ink">Helsepass</p>
              <p class="font-serif font-semibold text-ink text-sm mt-1">Ditt navn</p>
            </div>
          </div>
        </div>

        <!-- Checklist -->
        <ul class="space-y-4 mb-10">
          <li class="flex items-center gap-3 text-sm text-ink">
            <span class="w-6 h-6 rounded-full bg-sage/20 text-sage flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            </span>
            Gratis å opprette
          </li>
          <li class="flex items-center gap-3 text-sm text-ink">
            <span class="w-6 h-6 rounded-full bg-sage/20 text-sage flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            </span>
            Krypterte data, lagret i Norge
          </li>
          <li class="flex items-center gap-3 text-sm text-ink">
            <span class="w-6 h-6 rounded-full bg-sage/20 text-sage flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            </span>
            Du eier informasjonen din
          </li>
        </ul>

        <!-- Mini testimonial -->
        <div class="rounded-2xl bg-card/60 p-6 border border-edge">
          <p class="text-sm text-ink italic leading-relaxed mb-2">
            [KUNDEINNHOLD: Kort kundeuttalelse – f.eks. en setning fra en fornøyd bruker.]
          </p>
          <p class="text-xs text-muted-ink">— [KUNDEINNHOLD: Navn og sted]</p>
        </div>
      </div>

    </div>
  </section>

</Layout>

<script>
  import { createAccount } from '../utils/supabase';
  import type { AccountRecord } from '../utils/supabase';
  import { isValidEmail } from '../utils/validation';

  const form = document.getElementById('register-form') as HTMLFormElement | null;
  const successEl = document.getElementById('register-success');
  const errorEl = document.getElementById('register-error');
  const errorMsg = document.getElementById('register-error-msg');

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();

    // Reset alerts
    successEl?.classList.add('hidden');
    errorEl?.classList.add('hidden');

    // Gather values
    const get = (id: string) =>
      (document.getElementById(id) as HTMLInputElement | HTMLSelectElement | null)?.value.trim() ?? '';
    const samtykkeVilkar = (document.getElementById('samtykke-vilkar') as HTMLInputElement | null)?.checked ?? false;
    const samtykkeNyhetsbrev = (document.getElementById('samtykke-nyhetsbrev') as HTMLInputElement | null)?.checked ?? false;

    // Basic client-side validation
    const required = ['fornavn', 'etternavn', 'epost', 'passord', 'passord-bekreft'];
    for (const id of required) {
      if (!get(id)) {
        showError('Vennligst fyll ut alle obligatoriske felt.');
        return;
      }
    }

    if (!samtykkeVilkar) {
      showError('Du må godta vilkår og betingelser for å opprette en konto.');
      return;
    }

    if (!samtykkeNyhetsbrev) {
      showError('Du må samtykke til å motta nyhetsbrev for å opprette en konto.');
      return;
    }

    // Email validation
    const epost = get('epost');
    if (!isValidEmail(epost)) {
      showError('Vennligst oppgi en gyldig e-postadresse.');
      return;
    }

    const passord = get('passord');
    const passordBekreft = get('passord-bekreft');
    if (passord.length < 8) {
      showError('Passordet må være minst 8 tegn.');
      return;
    }

    if (passord !== passordBekreft) {
      showError('Passordene er ikke like.');
      return;
    }

    const data: AccountRecord = {
      fornavn: get('fornavn'),
      etternavn: get('etternavn'),
      epost,
      samtykke_vilkar: samtykkeVilkar,
      nyhetsbrev: samtykkeNyhetsbrev,
    };

    // Track with Umami
    if (typeof window !== 'undefined' && 'umami' in window) {
      // @ts-expect-error - umami is injected via script tag
      window.umami.track('register-form-submitted');
    }

    const result = await createAccount(data, passord);

    if (result.success) {
      successEl?.classList.remove('hidden');
      form.reset();
      form.classList.add('hidden');
      successEl?.scrollIntoView({ behavior: 'smooth', block: 'center' });
    } else {
      showError(result.error ?? 'En ukjent feil oppstod. Prøv igjen senere.');
    }
  });

  function showError(message: string) {
    if (errorEl && errorMsg) {
      errorMsg.textContent = message;
      errorEl.classList.remove('hidden');
      errorEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
  }
</script>
