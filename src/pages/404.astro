---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 – Side ikke funnet" description="Siden du leter etter finnes ikke.">
  <section class="min-h-[60vh] flex items-center justify-center py-20">
    <div class="max-w-md mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-8xl font-extrabold text-primary-200 mb-2" aria-hidden="true">404</p>
      <h1 class="text-3xl font-bold text-gray-900 mb-4">Side ikke funnet</h1>
      <p class="text-gray-500 mb-8 text-lg">
        Beklager, vi fant ikke siden du leter etter. Den kan ha blitt flyttet eller slettet.
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a
          href="/"
          class="inline-flex items-center justify-center px-6 py-3 bg-primary-600 text-white font-semibold rounded-lg hover:bg-primary-700 transition-colors"
          data-umami-event="404-go-home-click"
        >
          Gå til forsiden
        </a>
        <a
          href="/contact"
          class="inline-flex items-center justify-center px-6 py-3 border border-gray-300 text-gray-700 font-semibold rounded-lg hover:bg-gray-50 transition-colors"
          data-umami-event="404-contact-click"
        >
          Kontakt oss
        </a>
      </div>
    </div>
  </section>
</Layout>
