---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 – Side ikke funnet" description="Siden du leter etter finnes ikke.">
  <section class="min-h-[60vh] flex items-center justify-center py-20">
    <div class="max-w-md mx-auto px-6 text-center" data-hp-reveal>
      <p class="text-8xl font-extrabold text-sage/30 mb-2 font-serif" aria-hidden="true">404</p>
      <h1 class="font-serif text-3xl font-bold text-ink mb-4">Side ikke funnet</h1>
      <p class="text-muted-ink mb-8 text-lg">
        Beklager, vi fant ikke siden du leter etter. Den kan ha blitt flyttet eller slettet.
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a
          href="/"
          class="inline-flex items-center justify-center px-7 h-12 bg-forest text-forest-contrast font-medium rounded-full hover:bg-forest/90 transition-colors text-sm"
          data-umami-event="404-go-home-click"
        >
          Gå til forsiden
        </a>
        <a
          href="/about"
          class="inline-flex items-center justify-center px-7 h-12 border border-edge text-ink font-medium rounded-full hover:bg-mint transition-colors text-sm"
          data-umami-event="404-about-click"
        >
          Om oss
        </a>
      </div>
    </div>
  </section>
</Layout>
