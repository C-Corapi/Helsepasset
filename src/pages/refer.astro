---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Anbefal" description="Anbefal Helsepasset til noen du kjenner – del helseinformasjon med dem som trenger det.">
  <!-- Page header -->
  <section class="bg-gradient-to-br from-primary-700 to-primary-500 text-white py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl sm:text-5xl font-extrabold mb-4">Anbefal Helsepasset</h1>
      <p class="text-primary-100 text-lg max-w-xl mx-auto">
        Kjenner du noen som bør ha sitt eget helsepass? Send dem en invitasjon.
      </p>
    </div>
  </section>

  <!-- Referral form -->
  <section class="py-20" aria-labelledby="refer-form-heading">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 id="refer-form-heading" class="text-2xl font-bold text-gray-900 mb-2">Send en anbefaling</h2>
      <p class="text-gray-600 mb-8 leading-relaxed">
        Fyll ut skjemaet nedenfor, så sender vi en invitasjon til personen du anbefaler.
      </p>

      <!-- Success message (hidden by default) -->
      <div
        id="refer-success"
        class="hidden mb-6 p-4 bg-green-50 border border-green-200 text-green-800 rounded-lg"
        role="alert"
      >
        <p class="font-semibold">Anbefaling sendt!</p>
        <p class="text-sm mt-1">Takk for at du deler Helsepasset. Vi sender en invitasjon til personen du anbefalte.</p>
        <button
          id="refer-another-btn"
          type="button"
          class="mt-3 text-sm font-medium text-primary-600 hover:text-primary-700 underline"
        >
          Send en ny anbefaling →
        </button>
      </div>

      <!-- Error message (hidden by default) -->
      <div
        id="refer-error"
        class="hidden mb-6 p-4 bg-red-50 border border-red-200 text-red-800 rounded-lg"
        role="alert"
      >
        <p class="font-semibold">Noe gikk galt</p>
        <p id="refer-error-msg" class="text-sm mt-1"></p>
      </div>

      <form
        id="refer-form"
        class="space-y-6"
        novalidate
        aria-label="Anbefalingsskjema"
      >
        <!-- Sender info -->
        <fieldset>
          <legend class="text-lg font-semibold text-gray-900 mb-4">Dine opplysninger</legend>
          <div class="space-y-5">
            <div>
              <label for="avsender_navn" class="block text-sm font-medium text-gray-700 mb-1.5">
                Ditt navn <span class="text-red-500" aria-label="obligatorisk">*</span>
              </label>
              <input
                type="text"
                id="avsender_navn"
                name="avsender_navn"
                required
                autocomplete="name"
                class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors outline-none"
                placeholder="Ola Nordmann"
                aria-required="true"
              />
            </div>

            <div>
              <label for="avsender_epost" class="block text-sm font-medium text-gray-700 mb-1.5">
                Din e-post <span class="text-red-500" aria-label="obligatorisk">*</span>
              </label>
              <input
                type="email"
                id="avsender_epost"
                name="avsender_epost"
                required
                autocomplete="email"
                class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors outline-none"
                placeholder="ola@eksempel.no"
                aria-required="true"
              />
            </div>
          </div>
        </fieldset>

        <hr class="border-gray-200" />

        <!-- Recipient info -->
        <fieldset>
          <legend class="text-lg font-semibold text-gray-900 mb-4">Personen du vil anbefale</legend>
          <div class="space-y-5">
            <div>
              <label for="mottaker_navn" class="block text-sm font-medium text-gray-700 mb-1.5">
                Mottakers navn <span class="text-red-500" aria-label="obligatorisk">*</span>
              </label>
              <input
                type="text"
                id="mottaker_navn"
                name="mottaker_navn"
                required
                class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors outline-none"
                placeholder="Kari Nordmann"
                aria-required="true"
              />
            </div>

            <div>
              <label for="mottaker_epost" class="block text-sm font-medium text-gray-700 mb-1.5">
                Mottakers e-post <span class="text-red-500" aria-label="obligatorisk">*</span>
              </label>
              <input
                type="email"
                id="mottaker_epost"
                name="mottaker_epost"
                required
                class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors outline-none"
                placeholder="kari@eksempel.no"
                aria-required="true"
              />
            </div>

            <div>
              <label for="melding" class="block text-sm font-medium text-gray-700 mb-1.5">
                Personlig melding <span class="text-gray-400">(valgfritt)</span>
              </label>
              <textarea
                id="melding"
                name="melding"
                rows="3"
                class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors outline-none resize-y"
                placeholder="Hei! Jeg tror du bør sjekke ut Helsepasset..."
              ></textarea>
            </div>
          </div>
        </fieldset>

        <!-- Submit -->
        <button
          type="submit"
          class="w-full bg-primary-600 text-white font-semibold py-3 px-6 rounded-lg hover:bg-primary-700 active:bg-primary-800 transition-colors text-lg focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2"
          data-umami-event="refer-form-submit"
        >
          Send anbefaling
        </button>

        <p class="text-center text-sm text-gray-500 mt-4">
          Har du ikke en konto ennå?
          <a href="/registrer" class="text-primary-600 hover:text-primary-700 font-medium underline">
            Opprett konto →
          </a>
        </p>
      </form>
    </div>
  </section>
</Layout>

<script>
  import { createReferral } from '../utils/supabase';
  import type { ReferralRecord } from '../utils/supabase';
  import { isValidEmail } from '../utils/validation';

  const form = document.getElementById('refer-form') as HTMLFormElement | null;
  const successEl = document.getElementById('refer-success');
  const errorEl = document.getElementById('refer-error');
  const errorMsg = document.getElementById('refer-error-msg');
  const referAnotherBtn = document.getElementById('refer-another-btn');

  // Allow sending another referral after success
  referAnotherBtn?.addEventListener('click', () => {
    successEl?.classList.add('hidden');
    form?.classList.remove('hidden');
    form?.reset();
  });

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();

    // Reset alerts
    successEl?.classList.add('hidden');
    errorEl?.classList.add('hidden');

    // Gather values
    const get = (id: string) =>
      (document.getElementById(id) as HTMLInputElement | HTMLTextAreaElement | null)?.value.trim() ?? '';

    // Validate required fields
    const requiredFields = ['avsender_navn', 'avsender_epost', 'mottaker_navn', 'mottaker_epost'];
    for (const id of requiredFields) {
      if (!get(id)) {
        showError('Vennligst fyll ut alle obligatoriske felt.');
        return;
      }
    }

    // Email validation
    if (!isValidEmail(get('avsender_epost'))) {
      showError('Vennligst oppgi en gyldig e-postadresse for deg selv.');
      return;
    }
    if (!isValidEmail(get('mottaker_epost'))) {
      showError('Vennligst oppgi en gyldig e-postadresse for mottakeren.');
      return;
    }

    const data: ReferralRecord = {
      avsender_navn: get('avsender_navn'),
      avsender_epost: get('avsender_epost'),
      mottaker_navn: get('mottaker_navn'),
      mottaker_epost: get('mottaker_epost'),
      melding: get('melding') || undefined,
    };

    // Track with Umami
    if (typeof window !== 'undefined' && 'umami' in window) {
      // @ts-expect-error - umami is injected via script tag
      window.umami.track('refer-form-submitted');
    }

    const result = await createReferral(data);

    if (result.success) {
      successEl?.classList.remove('hidden');
      form.reset();
      form.classList.add('hidden');
      successEl?.scrollIntoView({ behavior: 'smooth', block: 'center' });
    } else {
      showError(result.error ?? 'En ukjent feil oppstod. Prøv igjen senere.');
    }
  });

  function showError(message: string) {
    if (errorEl && errorMsg) {
      errorMsg.textContent = message;
      errorEl.classList.remove('hidden');
      errorEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
  }
</script>
