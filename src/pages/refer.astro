---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Anbefal" description="Anbefal Helsepasset til noen du kjenner – del helseinformasjon med dem som trenger det.">

  <!-- Hero -->
  <section class="pt-32 pb-16">
    <div class="max-w-4xl mx-auto px-6 text-center" data-hp-reveal>
      <h1 class="font-serif font-bold text-ink text-4xl mb-4">Anbefal Helsepasset</h1>
      <p class="text-muted-ink text-lg max-w-xl mx-auto">
        Kjenner du noen som bør ha sitt eget helsepass? Send dem en invitasjon.
      </p>
    </div>
  </section>

  <!-- Referral form -->
  <section class="pb-24 md:pb-32" aria-labelledby="refer-form-heading">
    <div class="max-w-2xl mx-auto px-6" data-hp-reveal style="animation-delay: 80ms">
      <div class="rounded-3xl border border-edge bg-card p-8">
        <h2 id="refer-form-heading" class="font-serif text-xl font-semibold text-ink mb-2">Send en anbefaling</h2>
        <p class="text-muted-ink text-sm mb-8 leading-relaxed">
          Fyll ut skjemaet nedenfor, så sender vi en invitasjon til personen du anbefaler.
        </p>

        <!-- Success message -->
        <div
          id="refer-success"
          class="hidden mb-6 p-5 bg-sage/10 border border-sage/30 text-ink rounded-2xl"
          role="alert"
        >
          <p class="font-semibold mb-1">Anbefaling sendt!</p>
          <p class="text-sm text-muted-ink">Takk for at du deler Helsepasset. Vi sender en invitasjon til personen du anbefalte.</p>
          <button
            id="refer-another-btn"
            type="button"
            class="mt-3 text-sm font-medium text-forest underline hover:text-forest/80"
          >
            Send en ny anbefaling →
          </button>
        </div>

        <!-- Error message -->
        <div
          id="refer-error"
          class="hidden mb-6 p-5 bg-danger/5 border border-danger/20 text-ink rounded-2xl"
          role="alert"
        >
          <p class="font-semibold">Noe gikk galt</p>
          <p id="refer-error-msg" class="text-sm text-muted-ink mt-1"></p>
        </div>

        <form
          id="refer-form"
          class="space-y-6"
          novalidate
          aria-label="Anbefalingsskjema"
        >
          <!-- Sender info -->
          <fieldset>
            <legend class="text-base font-semibold text-ink mb-4">Dine opplysninger</legend>
            <div class="space-y-4">
              <div>
                <label for="avsender_navn" class="block text-sm font-medium text-ink mb-1.5">
                  Ditt navn <span class="text-danger" aria-label="obligatorisk">*</span>
                </label>
                <input
                  type="text"
                  id="avsender_navn"
                  name="avsender_navn"
                  required
                  autocomplete="name"
                  class="w-full px-4 py-2.5 border border-edge rounded-xl bg-sand focus:ring-2 focus:ring-focus focus:border-focus transition-colors outline-none text-ink"
                  placeholder="Ola Nordmann"
                  aria-required="true"
                />
              </div>
              <div>
                <label for="avsender_epost" class="block text-sm font-medium text-ink mb-1.5">
                  Din e-post <span class="text-danger" aria-label="obligatorisk">*</span>
                </label>
                <input
                  type="email"
                  id="avsender_epost"
                  name="avsender_epost"
                  required
                  autocomplete="email"
                  class="w-full px-4 py-2.5 border border-edge rounded-xl bg-sand focus:ring-2 focus:ring-focus focus:border-focus transition-colors outline-none text-ink"
                  placeholder="ola@eksempel.no"
                  aria-required="true"
                />
              </div>
            </div>
          </fieldset>

          <hr class="border-edge" />

          <!-- Recipient info -->
          <fieldset>
            <legend class="text-base font-semibold text-ink mb-4">Personen du vil anbefale</legend>
            <div class="space-y-4">
              <div>
                <label for="mottaker_navn" class="block text-sm font-medium text-ink mb-1.5">
                  Mottakers navn <span class="text-danger" aria-label="obligatorisk">*</span>
                </label>
                <input
                  type="text"
                  id="mottaker_navn"
                  name="mottaker_navn"
                  required
                  class="w-full px-4 py-2.5 border border-edge rounded-xl bg-sand focus:ring-2 focus:ring-focus focus:border-focus transition-colors outline-none text-ink"
                  placeholder="Kari Nordmann"
                  aria-required="true"
                />
              </div>
              <div>
                <label for="mottaker_epost" class="block text-sm font-medium text-ink mb-1.5">
                  Mottakers e-post <span class="text-danger" aria-label="obligatorisk">*</span>
                </label>
                <input
                  type="email"
                  id="mottaker_epost"
                  name="mottaker_epost"
                  required
                  class="w-full px-4 py-2.5 border border-edge rounded-xl bg-sand focus:ring-2 focus:ring-focus focus:border-focus transition-colors outline-none text-ink"
                  placeholder="kari@eksempel.no"
                  aria-required="true"
                />
              </div>
              <div>
                <label for="melding" class="block text-sm font-medium text-ink mb-1.5">
                  Personlig melding <span class="text-muted-ink">(valgfritt)</span>
                </label>
                <textarea
                  id="melding"
                  name="melding"
                  rows="3"
                  class="w-full px-4 py-2.5 border border-edge rounded-xl bg-sand focus:ring-2 focus:ring-focus focus:border-focus transition-colors outline-none resize-y text-ink"
                  placeholder="Hei! Jeg tror du bør sjekke ut Helsepasset..."
                ></textarea>
              </div>
            </div>
          </fieldset>

          <!-- Submit -->
          <button
            type="submit"
            class="w-full bg-forest text-forest-contrast font-semibold py-3 px-6 rounded-full hover:bg-forest/90 active:bg-forest/80 transition-colors text-sm focus:outline-none focus:ring-2 focus:ring-focus focus:ring-offset-2"
            data-umami-event="refer-form-submit"
          >
            Send anbefaling
          </button>

          <p class="text-center text-sm text-muted-ink mt-4">
            Har du ikke en konto ennå?
            <a href="/registrer" class="text-forest hover:text-forest/80 font-medium underline">
              Opprett konto →
            </a>
          </p>
        </form>
      </div>
    </div>
  </section>

</Layout>

<script>
  import { createReferral } from '../utils/supabase';
  import type { ReferralRecord } from '../utils/supabase';
  import { isValidEmail } from '../utils/validation';

  const form = document.getElementById('refer-form') as HTMLFormElement | null;
  const successEl = document.getElementById('refer-success');
  const errorEl = document.getElementById('refer-error');
  const errorMsg = document.getElementById('refer-error-msg');
  const referAnotherBtn = document.getElementById('refer-another-btn');

  referAnotherBtn?.addEventListener('click', () => {
    successEl?.classList.add('hidden');
    form?.classList.remove('hidden');
    form?.reset();
  });

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();

    successEl?.classList.add('hidden');
    errorEl?.classList.add('hidden');

    const get = (id: string) =>
      (document.getElementById(id) as HTMLInputElement | HTMLTextAreaElement | null)?.value.trim() ?? '';

    const requiredFields = ['avsender_navn', 'avsender_epost', 'mottaker_navn', 'mottaker_epost'];
    for (const id of requiredFields) {
      if (!get(id)) {
        showError('Vennligst fyll ut alle obligatoriske felt.');
        return;
      }
    }

    if (!isValidEmail(get('avsender_epost'))) {
      showError('Vennligst oppgi en gyldig e-postadresse for deg selv.');
      return;
    }
    if (!isValidEmail(get('mottaker_epost'))) {
      showError('Vennligst oppgi en gyldig e-postadresse for mottakeren.');
      return;
    }

    const data: ReferralRecord = {
      avsender_navn: get('avsender_navn'),
      avsender_epost: get('avsender_epost'),
      mottaker_navn: get('mottaker_navn'),
      mottaker_epost: get('mottaker_epost'),
      melding: get('melding') || undefined,
    };

    if (typeof window !== 'undefined' && 'umami' in window) {
      // @ts-expect-error - umami is injected via script tag
      window.umami.track('refer-form-submitted');
    }

    const result = await createReferral(data);

    if (result.success) {
      successEl?.classList.remove('hidden');
      form.reset();
      form.classList.add('hidden');
      successEl?.scrollIntoView({ behavior: 'smooth', block: 'center' });
    } else {
      showError(result.error ?? 'En ukjent feil oppstod. Prøv igjen senere.');
    }
  });

  function showError(message: string) {
    if (errorEl && errorMsg) {
      errorMsg.textContent = message;
      errorEl.classList.remove('hidden');
      errorEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
  }
</script>
