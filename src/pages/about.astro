---
import Layout from '../layouts/Layout.astro';

const values = [
  { title: '[Company value 1 – e.g. a word like "Integrity" or "Trust"]', description: '[One sentence describing what this value means in practice for Helsepasset]' },
  { title: '[Company value 2 – e.g. "Accessibility" or "Simplicity"]', description: '[One sentence describing what this value means in practice for Helsepasset]' },
  { title: '[Company value 3 – e.g. "Innovation" or "Care"]', description: '[One sentence describing what this value means in practice for Helsepasset]' },
];
---

<Layout title="Om oss" description="Lær mer om Helsepasset og vårt team.">
  <!-- Page header -->
  <section class="bg-gradient-to-br from-primary-700 to-primary-500 text-white py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl sm:text-5xl font-extrabold mb-4">[About page headline – e.g. "About Helsepasset"]</h1>
      <p class="text-primary-100 text-lg max-w-2xl mx-auto">
        [1–2 sentence company intro – who are Helsepasset, and what is their overall mission?]
      </p>
    </div>
  </section>

  <!-- Story -->
  <section class="py-20" aria-labelledby="story-heading">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 id="story-heading" class="text-3xl font-bold text-gray-900 mb-5">[Company story section heading – e.g. "Our story"]</h2>
          <p class="text-gray-600 leading-relaxed mb-4">
            [Company origin story – how and why was Helsepasset founded? What gap in the market did it address?]
          </p>
          <p class="text-gray-600 leading-relaxed mb-4">
            [Company mission and approach – what is the core mission, and how does Helsepasset pursue it?]
          </p>
          <p class="text-gray-600 leading-relaxed">
            [Current impact or reach – how many users/families does Helsepasset serve today, and what results have they seen?]
          </p>
        </div>
        <div class="bg-primary-50 rounded-2xl p-10 flex items-center justify-center" aria-hidden="true">
          <svg class="w-32 h-32 text-primary-400" viewBox="0 0 56 64" fill="none">
            <rect x="6" y="6" width="38" height="52" rx="3" stroke="currentColor" stroke-width="2.5"/>
            <path d="M36 6h8v8" stroke="currentColor" stroke-width="2.5" stroke-linejoin="round" fill="none"/>
            <line x1="36" y1="6" x2="44" y2="14" stroke="currentColor" stroke-width="1.5"/>
            <circle cx="25" cy="32" r="12" stroke="currentColor" stroke-width="2"/>
            <line x1="13" y1="32" x2="37" y2="32" stroke="currentColor" stroke-width="1.5"/>
            <ellipse cx="25" cy="32" rx="5.5" ry="12" stroke="currentColor" stroke-width="1.5" fill="none"/>
            <line x1="25" y1="24" x2="25" y2="40" stroke="#e87722" stroke-width="3" stroke-linecap="round"/>
            <line x1="17" y1="32" x2="33" y2="32" stroke="#e87722" stroke-width="3" stroke-linecap="round"/>
            <line x1="13" y1="50" x2="30" y2="50" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            <line x1="13" y1="54" x2="24" y2="54" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="py-20 bg-gray-50" aria-labelledby="values-heading">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 id="values-heading" class="text-3xl font-bold text-gray-900 text-center mb-12">[Values section heading – e.g. "Our values"]</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {values.map((value) => (
          <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 text-center">
            <h3 class="text-xl font-semibold text-primary-700 mb-3">{value.title}</h3>
            <p class="text-gray-500">{value.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact form -->
  <section class="py-20" aria-labelledby="contact-form-heading">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 id="contact-form-heading" class="text-3xl font-bold text-gray-900 mb-4 text-center">[Contact section heading – e.g. "Get in touch"]</h2>
      <p class="text-gray-500 mb-8 text-lg text-center">
        [One sentence inviting visitors to reach out – what kinds of enquiries are welcome?]
      </p>
      <form
        name="contact-message-form"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
        class="space-y-4 bg-white border border-gray-100 rounded-2xl p-6 shadow-sm"
        aria-label="Kontaktskjema"
      >
        <input type="hidden" name="form-name" value="contact-message-form" />
        <p class="hidden">
          <label>
            Ikke fyll ut dette feltet:
            <input name="bot-field" />
          </label>
        </p>
        <div>
          <label for="contact-name" class="block text-sm font-medium text-gray-700 mb-1.5">Navn</label>
          <input
            type="text"
            id="contact-name"
            name="contact-name"
            required
            aria-required="true"
            class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors outline-none"
            placeholder="Lorem Ipsum"
          />
        </div>
        <div>
          <label for="contact-email" class="block text-sm font-medium text-gray-700 mb-1.5">E-post</label>
          <input
            type="email"
            id="contact-email"
            name="contact-email"
            required
            aria-required="true"
            class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors outline-none"
            placeholder="lorem@ipsum.com"
          />
        </div>
        <div>
          <label for="contact-message" class="block text-sm font-medium text-gray-700 mb-1.5">Melding</label>
          <textarea
            id="contact-message"
            name="contact-message"
            rows="4"
            required
            aria-required="true"
            class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors outline-none resize-y"
            placeholder="Lorem ipsum dolor sit amet..."
          ></textarea>
        </div>
        <button
          type="submit"
          class="w-full sm:w-auto inline-flex items-center justify-center px-6 py-3 bg-primary-600 text-white font-semibold rounded-lg hover:bg-primary-700 transition-colors"
        >
          Send melding
        </button>
      </form>
    </div>
  </section>
</Layout>
