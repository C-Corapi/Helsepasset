---
import Layout from '../layouts/Layout.astro';

const values = [
  {
    title: 'Integritet',
    description: '[KUNDEINNHOLD: Beskrivelse av integritet – f.eks. konfidensialitet og respekt for helseinformasjon]',
    iconPath: 'M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z',
  },
  {
    title: 'Tilgjengelighet',
    description: '[KUNDEINNHOLD: Beskrivelse av tilgjengelighet – f.eks. alltid tilgjengelig, uansett tid og sted]',
    iconPath: 'M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
  },
  {
    title: 'Innovasjon',
    description: '[KUNDEINNHOLD: Beskrivelse av innovasjon – f.eks. moderne teknologi og brukeropplevelse]',
    iconPath: 'M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z',
  },
];

const milestones = [
  { year: '[KUNDEINNHOLD: Årstall]', label: '[KUNDEINNHOLD: Milepæl 1 – f.eks. "Idéen blir til"]' },
  { year: '[KUNDEINNHOLD: Årstall]', label: '[KUNDEINNHOLD: Milepæl 2 – f.eks. "Første versjon lanseres"]' },
  { year: '[KUNDEINNHOLD: Årstall]', label: '[KUNDEINNHOLD: Milepæl 3 – f.eks. "X antall brukere"]' },
];
---

<Layout title="Om Helsepasset — Trygg helseoversikt hvor enn du er" description="Lær mer om Helsepasset og vårt team.">

  <!-- Hero -->
  <section class="pt-32 pb-20">
    <div class="max-w-[1200px] mx-auto px-6 text-center" data-hp-reveal>
      <span class="inline-block text-sm font-medium text-muted-ink uppercase tracking-wider mb-4">Om oss</span>
      <h1 class="font-serif font-bold text-ink mb-5" style="font-size: clamp(2.5rem, 5vw, 4rem);">Om Helsepasset</h1>
      <p class="text-muted-ink text-lg max-w-2xl mx-auto" style="font-size: 1.0625rem; line-height: 1.7;">
        [KUNDEINNHOLD: Introduksjonstekst om Helsepasset og teamet bak]
      </p>
    </div>
  </section>

  <!-- Vår historie -->
  <section class="py-24 md:py-32" aria-labelledby="story-heading">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div data-hp-reveal>
          <h2 id="story-heading" class="font-serif font-bold text-ink text-3xl mb-6">Vår historie</h2>
          <p class="text-muted-ink leading-relaxed mb-4">
            [KUNDEINNHOLD: Første avsnitt om historien til Helsepasset – f.eks. bakgrunn og visjon]
          </p>
          <p class="text-muted-ink leading-relaxed mb-4">
            [KUNDEINNHOLD: Andre avsnitt – f.eks. utvikling, samarbeid, og teknologi]
          </p>
          <p class="text-muted-ink leading-relaxed">
            [KUNDEINNHOLD: Tredje avsnitt – f.eks. nåsituasjon, brukertall, og fremtidsplaner]
          </p>
        </div>
        <!-- Pull-quote card -->
        <div class="bg-mint rounded-3xl p-10 flex flex-col justify-center" data-hp-reveal style="animation-delay: 80ms">
          <svg class="w-8 h-8 text-sage/50 mb-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C7.546 6.068 5.983 8.789 5.983 11h4v10H0z"/>
          </svg>
          <blockquote class="font-serif text-xl text-ink leading-relaxed italic">
            [KUNDEINNHOLD: Sitat eller visjon som oppsummerer Helsepassets kjerneverdier]
          </blockquote>
        </div>
      </div>
    </div>
  </section>

  <!-- Våre verdier -->
  <section class="py-24 md:py-32 bg-mint/30" aria-labelledby="values-heading">
    <div class="max-w-[1200px] mx-auto px-6">
      <h2 id="values-heading" class="font-serif font-bold text-ink text-center text-3xl mb-14" data-hp-reveal>Våre verdier</h2>
      <div class="grid md:grid-cols-3 gap-6">
        {values.map((v, i) => (
          <div
            class="group p-8 rounded-3xl border border-edge bg-card transition-all duration-300 hover:-translate-y-1 hover:shadow-hp-lg hover:border-sage"
            data-hp-reveal
            style={`animation-delay: ${i * 80}ms`}
          >
            <div class="h-12 w-12 rounded-2xl bg-mint text-forest flex items-center justify-center mb-5 transition-transform duration-300 group-hover:scale-110 group-hover:rotate-3">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d={v.iconPath} />
              </svg>
            </div>
            <h3 class="font-serif text-xl font-semibold text-ink mb-2">{v.title}</h3>
            <p class="text-muted-ink leading-relaxed">{v.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Tidslinje -->
  <section class="py-24 md:py-32" aria-labelledby="timeline-heading">
    <div class="max-w-3xl mx-auto px-6">
      <h2 id="timeline-heading" class="font-serif font-bold text-ink text-center text-3xl mb-14" data-hp-reveal>Vår reise</h2>
      <div class="relative pl-8 border-l-2 border-sage/30 space-y-12" data-hp-reveal style="animation-delay: 80ms">
        {milestones.map((m) => (
          <div class="relative">
            <div class="absolute -left-[2.6rem] top-1 w-5 h-5 rounded-full bg-sage border-4 border-sand"></div>
            <span class="block text-sm font-semibold text-sage mb-1">{m.year}</span>
            <p class="text-ink font-medium">{m.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Kontakt eierne -->
  <section class="py-24 md:py-32" aria-labelledby="owners-heading">
    <div class="max-w-2xl mx-auto px-6 text-center" data-hp-reveal>
      <div class="bg-mint rounded-3xl p-10 md:p-14">
        <h2 id="owners-heading" class="font-serif font-bold text-ink text-2xl mb-4">Kontakt eierne</h2>
        <p class="text-muted-ink mb-6">
          [KUNDEINNHOLD: Kort beskrivelse av kontaktmuligheter og hvem man når]
        </p>
        <p class="font-medium text-ink mb-1">
          E-post: <a href="mailto:post@helsepasset.no" class="text-forest underline hover:text-forest/80">post@helsepasset.no</a>
        </p>
        <p class="text-muted-ink text-sm">Oslo, Norge</p>
      </div>
    </div>
  </section>

</Layout>
