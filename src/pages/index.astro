---
import Layout from '../layouts/Layout.astro';

const features = [
  {
    title: 'Trygg og pålitelig',
    description: 'Vi leverer helsetjenester med høyeste standard for sikkerhet og pålitelighet for deg og din familie.',
    iconPath: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
  },
  {
    title: 'Personlig oppfølging',
    description: 'Dedikert team som følger deg opp gjennom hele prosessen med personlig og profesjonell service.',
    iconPath: 'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z',
  },
  {
    title: 'Enkel administrasjon',
    description: 'Smidig håndtering av helsepass og dokumentasjon, slik at du kan fokusere på det viktigste.',
    iconPath: 'M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z',
  },
];

const steps = [
  { n: 1, title: 'Opprett kontoen din', body: '[KUNDEINNHOLD: Beskriv kort registreringsprosessen – f.eks. tidsbruk, hva som trengs]' },
  { n: 2, title: 'Fyll inn helseinformasjon', body: '[KUNDEINNHOLD: Beskriv hvilke opplysninger brukeren legger inn – vaksiner, allergier, etc.]' },
  { n: 3, title: 'Del trygt ved behov', body: '[KUNDEINNHOLD: Beskriv delefunksjonen – f.eks. QR-kode til helsepersonell]' },
];

const stats = [
  { value: '[KUNDEINNHOLD: Antall]', label: '[KUNDEINNHOLD: Merkelapp – f.eks. "Aktive brukere"]' },
  { value: '[KUNDEINNHOLD: Tall]', label: '[KUNDEINNHOLD: Merkelapp – f.eks. "Tilgjengelighet"]' },
  { value: '[KUNDEINNHOLD: Tall]', label: '[KUNDEINNHOLD: Merkelapp – f.eks. "Oppetid"]' },
  { value: '[KUNDEINNHOLD: Tall]', label: '[KUNDEINNHOLD: Merkelapp – f.eks. "Krypteringstype"]' },
];

const faqItems = [
  {
    q: '[KUNDEINNHOLD: Spørsmål 1 – f.eks. "Er informasjonen min trygg?"]',
    a: '[KUNDEINNHOLD: Svar på spørsmål 1 – beskriv sikkerheten, GDPR, lagring osv.]',
  },
  {
    q: '[KUNDEINNHOLD: Spørsmål 2 – f.eks. "Hva koster Helsepasset?"]',
    a: '[KUNDEINNHOLD: Svar på spørsmål 2 – beskriv prismodell/gratis funksjoner]',
  },
  {
    q: '[KUNDEINNHOLD: Spørsmål 3 – f.eks. "Kan jeg dele info med legen min?"]',
    a: '[KUNDEINNHOLD: Svar på spørsmål 3 – beskriv delingsfunksjonalitet]',
  },
  {
    q: '[KUNDEINNHOLD: Spørsmål 4 – f.eks. "Fungerer det uten internett?"]',
    a: '[KUNDEINNHOLD: Svar på spørsmål 4 – beskriv offlinefunksjonalitet]',
  },
  {
    q: '[KUNDEINNHOLD: Spørsmål 5 – f.eks. "Hvordan sletter jeg kontoen?"]',
    a: '[KUNDEINNHOLD: Svar på spørsmål 5 – beskriv kontosletting]',
  },
];
---

<Layout title="Helsepasset — Ditt helsepass, alltid med deg" description="Helsepasset – din pålitelige partner for helsetjenester i Norge.">

  <!-- JSON-LD Organization -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Helsepasset",
    "url": Astro.url.origin,
    "description": "Helsepasset samler all viktig helseinformasjon på ett sted."
  })} />

  <!-- ========== 1. HERO ========== -->
  <section class="relative overflow-hidden pt-32 pb-24" aria-labelledby="hero-heading">
    <div class="max-w-[1200px] mx-auto px-6 grid md:grid-cols-2 gap-16 items-center">
      <!-- Left column -->
      <div data-hp-reveal>
        <span class="inline-flex items-center gap-2 bg-mint text-mint-contrast text-sm px-4 py-1.5 rounded-full mb-6">
          <span class="w-2 h-2 rounded-full bg-sage" aria-hidden="true"></span>
          Ny tjeneste tilgjengelig
        </span>
        <h1 id="hero-heading" class="font-serif font-bold mb-6" style="font-size: clamp(2.5rem, 6vw, 4.5rem); line-height: 1.1;">
          Ditt helsepass — <span class="text-peach">hvor enn du er</span>
        </h1>
        <p class="text-muted-ink text-lg leading-relaxed mb-8 max-w-lg" style="font-size: 1.0625rem; line-height: 1.7;">
          Helsepasset samler all viktig helseinformasjon på ett sted. Trygt, enkelt og alltid oppdatert.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 mb-8">
          <a
            href="/registrer"
            class="inline-flex items-center justify-center bg-forest text-forest-contrast font-medium px-7 h-12 rounded-full hover:bg-forest/90 hover:shadow-hp-lg transition-all duration-200 text-sm"
            data-umami-event="hero-cta-primary-click"
          >
            Opprett konto gratis
          </a>
          <a
            href="/about"
            class="inline-flex items-center justify-center border border-forest text-forest font-medium px-7 h-12 rounded-full hover:bg-forest hover:text-forest-contrast transition-all duration-200 text-sm"
            data-umami-event="hero-cta-secondary-click"
          >
            Les mer om oss
          </a>
        </div>
        <!-- Trust row -->
        <div class="flex flex-wrap items-center gap-6 text-xs text-muted-ink">
          <span class="inline-flex items-center gap-1.5">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
            GDPR
          </span>
          <span class="inline-flex items-center gap-1.5">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="2" y="2" width="20" height="8" rx="2" ry="2"/><rect x="2" y="14" width="20" height="8" rx="2" ry="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>
            Norsk hosting
          </span>
          <span class="inline-flex items-center gap-1.5">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            Kryptert
          </span>
        </div>
      </div>

      <!-- Right column — Phone mockup -->
      <div class="relative flex justify-center" data-hp-reveal style="animation-delay: 80ms" aria-hidden="true">
        <!-- Ambient blob -->
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-80 h-80 bg-mint rounded-full blur-3xl opacity-60"></div>

        <!-- Phone frame -->
        <div class="relative rounded-[2.5rem] border-8 border-ink/90 bg-card w-72 shadow-hp-lg overflow-hidden" style="aspect-ratio: 9/19;">
          <!-- Notch -->
          <div class="absolute top-0 left-1/2 -translate-x-1/2 w-24 h-6 bg-ink/90 rounded-b-2xl"></div>
          <!-- Card content inside phone -->
          <div class="flex flex-col items-center justify-center h-full px-6 py-12">
            <div class="w-full rounded-2xl bg-gradient-to-br from-sage/40 to-secondary p-5 mb-4">
              <p class="text-[10px] uppercase tracking-widest text-muted-ink mb-1">Helsepass</p>
              <p class="font-serif font-semibold text-ink text-lg">Ingrid Hansen</p>
              <p class="text-xs text-muted-ink mb-3">Blodtype: A+</p>
              <!-- QR placeholder -->
              <div class="w-16 h-16 mx-auto rounded-lg bg-ink/10 flex items-center justify-center">
                <svg class="w-8 h-8 text-ink/30" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="4" height="4" rx="0.5"/><rect x="19" y="19" width="2" height="2" rx="0.3"/>
                </svg>
              </div>
            </div>
          </div>
        </div>

        <!-- Floating chips -->
        <div class="absolute top-8 -left-4 bg-card rounded-2xl px-4 py-2.5 shadow-hp text-xs font-medium flex items-center gap-2 animate-hp-drift" style="animation-delay: 0s;">
          <svg class="w-4 h-4 text-sage" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>
          <span>Vaksiner ✓</span>
        </div>
        <div class="absolute top-1/3 -right-6 bg-card rounded-2xl px-4 py-2.5 shadow-hp text-xs font-medium flex items-center gap-2 animate-hp-drift" style="animation-delay: 1.5s;">
          <svg class="w-4 h-4 text-peach" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
          <span>Allergier</span>
        </div>
        <div class="absolute bottom-12 -left-2 bg-card rounded-2xl px-4 py-2.5 shadow-hp text-xs font-medium flex items-center gap-2 animate-hp-drift" style="animation-delay: 3s;">
          <svg class="w-4 h-4 text-forest" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          <span>Kontakt</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== 2. TRUST STRIP ========== -->
  <section class="bg-mint/40 py-8" aria-label="Partnere og sertifiseringer">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="flex flex-wrap items-center justify-center gap-8 md:gap-16 text-sm font-medium text-muted-ink/60">
        <span>[KUNDEINNHOLD: Partner/sertifisering 1 – f.eks. logo eller navn]</span>
        <span>[KUNDEINNHOLD: Partner/sertifisering 2]</span>
        <span>[KUNDEINNHOLD: Partner/sertifisering 3]</span>
        <span>[KUNDEINNHOLD: Partner/sertifisering 4]</span>
      </div>
    </div>
  </section>

  <!-- ========== 3. FEATURES ========== -->
  <section class="py-24 md:py-32" aria-labelledby="features-heading">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="text-center mb-16" data-hp-reveal>
        <h2 id="features-heading" class="font-serif font-bold text-ink mb-4" style="font-size: clamp(2rem, 4vw, 3rem);">Hvorfor velge Helsepasset?</h2>
        <p class="text-muted-ink max-w-xl mx-auto" style="font-size: 1.0625rem; line-height: 1.7;">Vi gjør det enkelt å ha oversikt over helsen din – uansett hvor du er.</p>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {features.map((f, i) => (
          <div
            class="group p-8 rounded-3xl border border-edge bg-card transition-all duration-300 hover:-translate-y-1 hover:shadow-hp-lg hover:border-sage"
            data-hp-reveal
            style={`animation-delay: ${i * 80}ms`}
          >
            <div class="h-12 w-12 rounded-2xl bg-mint text-forest flex items-center justify-center mb-5 transition-transform duration-300 group-hover:scale-110 group-hover:rotate-3">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d={f.iconPath} />
              </svg>
            </div>
            <h3 class="font-serif text-xl font-semibold text-ink mb-2">{f.title}</h3>
            <p class="text-muted-ink leading-relaxed mb-4">{f.description}</p>
            <span class="text-sm font-medium text-forest opacity-0 group-hover:opacity-100 transition-opacity duration-200">Les mer →</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== 4. HOW IT WORKS (Step Timeline) ========== -->
  <section class="py-24 md:py-32 bg-mint/30" aria-labelledby="steps-heading">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="text-center mb-16" data-hp-reveal>
        <h2 id="steps-heading" class="font-serif font-bold text-ink mb-4" style="font-size: clamp(2rem, 4vw, 3rem);">Slik fungerer det</h2>
      </div>
      <div class="relative grid md:grid-cols-3 gap-8">
        <!-- Connector line (desktop only) -->
        <div class="hidden md:block absolute top-10 left-[16.67%] right-[16.67%] h-0.5 bg-border" aria-hidden="true">
          <div id="timeline-fill" class="h-full bg-sage origin-left transition-transform duration-1000" style="transform: scaleX(0);"></div>
        </div>
        {steps.map((step, i) => (
          <div class="relative text-center" data-hp-reveal style={`animation-delay: ${i * 80}ms`}>
            <div class="relative z-10 w-14 h-14 rounded-full bg-sage text-white text-xl font-bold flex items-center justify-center mx-auto mb-6 shadow-hp">
              {step.n}
            </div>
            <h3 class="font-serif text-xl font-semibold text-ink mb-2">{step.title}</h3>
            <p class="text-muted-ink text-sm leading-relaxed max-w-xs mx-auto">{step.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== 5. FEATURE SPLIT — "Alltid med deg" ========== -->
  <section class="py-24 md:py-32" aria-labelledby="feature-mobile-heading">
    <div class="max-w-[1200px] mx-auto px-6 grid md:grid-cols-2 gap-16 items-center">
      <div data-hp-reveal>
        <h2 id="feature-mobile-heading" class="font-serif font-bold text-ink mb-4" style="font-size: clamp(2rem, 4vw, 3rem);">Alltid med deg, hvor enn du er</h2>
        <p class="text-muted-ink mb-6" style="font-size: 1.0625rem; line-height: 1.7;">
          [KUNDEINNHOLD: Beskriv hvordan appen fungerer på mobil – f.eks. mobiltilpasset design, tilgjengelighet uten nett, etc.]
        </p>
        <ul class="space-y-3">
          <li class="flex items-center gap-3">
            <span class="w-6 h-6 rounded-full bg-sage/20 text-sage flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            </span>
            <span class="text-ink text-sm">[KUNDEINNHOLD: Fordel 1 – f.eks. "Fungerer offline"]</span>
          </li>
          <li class="flex items-center gap-3">
            <span class="w-6 h-6 rounded-full bg-sage/20 text-sage flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            </span>
            <span class="text-ink text-sm">[KUNDEINNHOLD: Fordel 2 – f.eks. "Sikker biometrisk innlogging"]</span>
          </li>
          <li class="flex items-center gap-3">
            <span class="w-6 h-6 rounded-full bg-sage/20 text-sage flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            </span>
            <span class="text-ink text-sm">[KUNDEINNHOLD: Fordel 3 – f.eks. "Synkroniseres på tvers av enheter"]</span>
          </li>
        </ul>
      </div>
      <!-- Visual: phone-in-hand illustration (SVG) -->
      <div class="flex justify-center" data-hp-reveal style="animation-delay: 80ms" aria-hidden="true">
        <div class="relative w-64">
          <div class="rounded-[2rem] border-4 border-ink/20 bg-gradient-to-br from-sage/20 to-secondary p-8 aspect-[9/16] flex flex-col items-center justify-center shadow-hp">
            <svg class="w-16 h-16 text-sage/60 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/>
            </svg>
            <p class="text-xs text-muted-ink text-center">Alltid i lomma</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== 6. FEATURE SPLIT — "Del trygt" ========== -->
  <section class="py-24 md:py-32 bg-mint/30" aria-labelledby="feature-share-heading">
    <div class="max-w-[1200px] mx-auto px-6 grid md:grid-cols-2 gap-16 items-center">
      <!-- Visual: QR card -->
      <div class="flex justify-center order-2 md:order-1" data-hp-reveal aria-hidden="true">
        <div class="rounded-3xl bg-card border border-edge p-10 shadow-hp w-72">
          <p class="text-xs uppercase tracking-widest text-muted-ink mb-4">Del helsepass</p>
          <div class="w-32 h-32 mx-auto rounded-xl bg-ink/5 flex items-center justify-center mb-4">
            <svg class="w-16 h-16 text-ink/20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="4" height="4" rx="0.5"/><rect x="19" y="19" width="2" height="2" rx="0.3"/>
            </svg>
          </div>
          <p class="text-xs text-center text-muted-ink">Skann for helseinformasjon</p>
        </div>
      </div>
      <!-- Text -->
      <div class="order-1 md:order-2" data-hp-reveal style="animation-delay: 80ms">
        <h2 id="feature-share-heading" class="font-serif font-bold text-ink mb-4" style="font-size: clamp(2rem, 4vw, 3rem);">Del trygt med helsepersonell</h2>
        <p class="text-muted-ink" style="font-size: 1.0625rem; line-height: 1.7;">
          [KUNDEINNHOLD: Beskriv hvordan QR-delingen fungerer – hva deles, hvem kontrollerer tilgang, og i hvilke situasjoner det brukes.]
        </p>
      </div>
    </div>
  </section>

  <!-- ========== 7. STATS STRIP ========== -->
  <section class="py-16 bg-gradient-to-br from-sage/30 to-secondary" aria-label="Nøkkeltall">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center" data-hp-reveal>
        {stats.map((s) => (
          <div>
            <p class="font-serif text-3xl md:text-4xl font-bold text-ink">{s.value}</p>
            <p class="text-sm text-muted-ink mt-1">{s.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== 9. FAQ ========== -->
  <section class="py-24 md:py-32 bg-mint/30" aria-labelledby="faq-heading">
    <div class="max-w-3xl mx-auto px-6">
      <div class="text-center mb-12" data-hp-reveal>
        <h2 id="faq-heading" class="font-serif font-bold text-ink mb-4" style="font-size: clamp(2rem, 4vw, 3rem);">Ofte stilte spørsmål</h2>
      </div>
      <div class="space-y-3" data-hp-reveal style="animation-delay: 80ms">
        {faqItems.map((item) => (
          <details class="group rounded-2xl border border-edge bg-card overflow-hidden">
            <summary class="flex items-center justify-between cursor-pointer p-5 text-ink font-medium text-sm hover:bg-mint/50 transition-colors list-none [&::-webkit-details-marker]:hidden">
              <span>{item.q}</span>
              <svg class="w-5 h-5 text-muted-ink flex-shrink-0 transition-transform duration-200 group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <polyline points="6 9 12 15 18 9" />
              </svg>
            </summary>
            <div class="px-5 pb-5 text-muted-ink text-sm leading-relaxed">
              {item.a}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== 10. CTA BAND ========== -->
  <section class="relative py-24 md:py-32 bg-forest text-forest-contrast overflow-hidden" aria-labelledby="cta-heading">
    <!-- Sage radial overlay -->
    <div class="absolute inset-0 opacity-20" style="background: radial-gradient(ellipse at center, hsl(144 28% 61% / 0.4), transparent 70%);" aria-hidden="true"></div>
    <div class="relative max-w-3xl mx-auto px-6 text-center" data-hp-reveal>
      <h2 id="cta-heading" class="font-serif font-bold mb-4" style="font-size: clamp(2rem, 4vw, 3rem);">Klar til å ta kontroll over helsen din?</h2>
      <p class="text-forest-contrast/80 text-lg mb-8 max-w-xl mx-auto">
        Ta kontakt i dag og la oss hjelpe deg med å sette opp ditt personlige helsepass.
      </p>
      <a
        href="/registrer"
        class="inline-flex items-center justify-center bg-peach text-peach-contrast font-medium px-8 h-12 rounded-full hover:brightness-105 transition-all shadow-hp text-sm"
        data-umami-event="bottom-cta-click"
      >
        Opprett konto nå
      </a>
    </div>
  </section>

</Layout>

<script>
  // Timeline fill animation on scroll
  const fill = document.getElementById('timeline-fill');
  if (fill) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          fill.style.transform = 'scaleX(1)';
          observer.disconnect();
        }
      },
      { threshold: 0.3 }
    );
    observer.observe(fill.parentElement!);
  }
</script>
