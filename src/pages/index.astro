---
import Layout from '../layouts/Layout.astro';

const features = [
  {
    icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
    title: '[Reason 1 to use Helsepasset – e.g. a key benefit or unique selling point]',
    description: '[One sentence expanding on reason 1 – what problem does it solve for the user?]',
  },
  {
    icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z',
    title: '[Reason 2 to use Helsepasset – e.g. a second key benefit]',
    description: '[One sentence expanding on reason 2 – what does Helsepasset offer that others don\'t?]',
  },
  {
    icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4',
    title: '[Reason 3 to use Helsepasset – e.g. a third key benefit]',
    description: '[One sentence expanding on reason 3 – focus on ease of use, access, or value]',
  },
];
---

<Layout title="Hjem" description="Helsepasset – din pålitelige partner for helsetjenester i Norge.">
  <!-- Hero section -->
  <section class="relative bg-gradient-to-br from-primary-700 to-primary-500 text-white overflow-hidden">
    <div class="absolute inset-0 opacity-10" aria-hidden="true" style="background-image: radial-gradient(circle, rgba(255,255,255,0.4) 1px, transparent 1px); background-size: 24px 24px;"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-32 text-center">
      <h1 class="text-4xl sm:text-5xl md:text-6xl font-extrabold leading-tight mb-6">
        [Main headline / tagline for Helsepasset] –<br />
        <span class="text-accent-300">[Short punchy subphrase – e.g. the brand slogan]</span>
      </h1>
      <p class="text-lg sm:text-xl text-primary-100 max-w-2xl mx-auto mb-10">
        [2–3 sentence product description – what is Helsepasset, who is it for, and what problem does it solve?]
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a
          href="/registrer"
          class="inline-flex items-center justify-center px-8 py-3 bg-white text-primary-700 font-semibold rounded-lg shadow hover:bg-primary-50 hover:-translate-y-0.5 transition-all duration-200 ease-in-out text-lg"
          data-umami-event="hero-cta-primary-click"
        >
          Opprett konto
        </a>
        <a
          href="/about"
          class="inline-flex items-center justify-center px-8 py-3 border-2 border-white/70 text-white font-semibold rounded-lg hover:bg-white/10 hover:-translate-y-0.5 transition-all duration-200 ease-in-out text-lg"
          data-umami-event="hero-cta-secondary-click"
        >
          Les mer om oss
        </a>
      </div>
    </div>
  </section>

  <!-- Features / Services -->
  <section class="py-20 bg-gray-50" aria-labelledby="features-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <h2 id="features-heading" class="text-3xl sm:text-4xl font-bold text-gray-900 mb-4">[Section heading – e.g. "Why choose Helsepasset?"]</h2>
        <p class="text-gray-500 max-w-xl mx-auto text-lg">[One sentence intro to the features section – what makes Helsepasset stand out?]</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {features.map((feature) => (
          <div class="bg-white rounded-2xl p-8 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-200 ease-in-out border border-gray-100">
            <div class="w-12 h-12 bg-primary-100 text-primary-600 rounded-xl flex items-center justify-center mb-5">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d={feature.icon} />
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-gray-900 mb-2">{feature.title}</h3>
            <p class="text-gray-500 leading-relaxed">{feature.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Call to action -->
  <section class="py-20 bg-primary-700 text-white" aria-labelledby="cta-heading">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 id="cta-heading" class="text-3xl sm:text-4xl font-bold mb-4">[Call-to-action headline – e.g. "Ready to take control of your health?"]</h2>
      <p class="text-primary-100 text-lg mb-8 max-w-xl mx-auto">
        [1–2 sentences encouraging the user to sign up – what will they gain by creating an account?]
      </p>
      <a
        href="/registrer"
        class="inline-flex items-center justify-center px-10 py-4 bg-white text-primary-700 font-bold rounded-lg text-lg hover:bg-primary-50 hover:-translate-y-0.5 transition-all duration-200 ease-in-out shadow-lg"
        data-umami-event="bottom-cta-click"
      >
        [CTA button label – e.g. "Create account now"]
      </a>
    </div>
  </section>
</Layout>
