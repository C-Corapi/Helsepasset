# Umami Analytics
# URL to the Umami script.js served by your Umami instance
PUBLIC_UMAMI_URL=https://your-umami-instance.netlify.app/script.js

# Umami website tracking ID (UUID found in Settings → Websites)
PUBLIC_UMAMI_WEBSITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Supabase
# Your Supabase project URL (found in Settings → API)
PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase public anon key (found in Settings → API → anon/public)
PUBLIC_SUPABASE_ANON_KEY=your-anon-key
